---
import { getLocalePrefix, type Locale } from "../../../i18n/config";
import Layout from '../../../layouts/Layout.astro';
import TourPageClient from '../../../components/TourPageClient';
import { getAllTours } from '../../../lib/wordpress/api';

// Generate static paths for all tours (lightweight: only fetches slug list)
export async function getStaticPaths() {
  const locales = ['en', 'zh'] as const;
  const paths = [];

  for (const locale of locales) {
    const tours = await getAllTours(locale);
    for (const tour of tours) {
      paths.push({
        params: {
          lang: locale === 'en' ? undefined : locale,
          slug: decodeURIComponent(tour.slug),
        },
      });
    }
  }

  return paths;
}

const { slug, lang: langParam } = Astro.params;
const lang: Locale = (langParam as Locale) || 'en';
const localePrefix = getLocalePrefix(lang as Locale);
---

<Layout
  title="Tour | Qualitour"
  description="Discover premium tours and travel experiences with Qualitour."
  lang={lang}
>
  <TourPageClient slug={slug as string} lang={lang} localePrefix={localePrefix} client:load />
</Layout>
